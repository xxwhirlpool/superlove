<!--Descriptive page names, messages and instructions-->
<%= render "muted/muted_items_notice" %>

<h2><%= ts('Search Results') %></h2>

<p>
  <%= ts("You searched for:") %>
  <%= (sanitize @search.summary, tags: %w[span], attributes: %w[lang]).html_safe %>
</p>

<!--/descriptions-->

<!--subnav-->
<div class="actions" role="navigation">
  <%= link_to ts("Edit Your Search"), current_path_with(edit_search: true) %>
</div>
<!--/subnav-->

<!--main content-->
<% if @works.blank? %>
  <p><%= ts("No results found. You may want to edit your search to make it less specific.") %></p>
<% else %>
  <h3><%= search_results_found(@works) %> <%= link_to_help "work-search-results-help" %></h3>
  <ol class="index">
    <% @works.each do |work| %>
      <% unless work.nil? %>
        <%= render :partial => 'work_blurb', :locals => {:work => work} %>
      <% end %>
    <% end %>
  </ol>
 
 <%= will_paginate @works %>
<% end %>
<!--/content-->
