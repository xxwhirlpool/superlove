<!--main content-->
<div class="notes">
  <%= ts("Some commonly asked questions about superlove are answered here.") %>
  <%= ts("If you need more help, please ") %> <%= link_to ts("contact the admin"), feedbacks_path %>.
</div>

<% if @archive_faqs.blank? %>
  <div class="notice"><%= ts("We're sorry, there are currently no entries in the FAQ System.") %></div>
<% else %>
  <div #{rtl? ? 'dir="rtl"' : ''} class="categories">
    <h3>
      <%= ts("Available Categories") %>
      <ul class="actions">
        <li id="expand-categories"><%= link_to ts("Expand Categories"), "#" %></li>
        <li id="collapse-categories"><%= link_to ts("Collapse Categories"), "#" %></li>
      </ul>
    </h3>
    <% for faq in @archive_faqs %>
      <details>
        <summary><%= faq.title %></summary>
        <ul class="questions">
          <% english? ? questions = faq.questions : questions = translated_questions(faq.questions) %>
          <% if questions.blank? %>
            <li><%= ts("There are no questions in this category yet.") %></li>
          <% else %>
            <% for q in questions %>
              <li>
                <%= link_to q.question, archive_faq_path(faq, :anchor => q.anchor) %>
                <% unless q.screencast.to_s.empty? %>
                  <span class="screencast">
                    <%= ts("(Screencast available)") %>
                  </span>
                <% end %>
              </li>
            <% end %>
          <% end %>
        </ul>
      </details>
    <% end %>
  </div>
  <script type="text/javascript">
    const expand = document.getElementById('expand-categories');
    const collapse = document.getElementById('collapse-categories');
  
    expand.addEventListener('click', (e) => {
      e.preventDefault();
      document.querySelectorAll('#content details').forEach((elt) => {
        elt.setAttribute('open', '');
      });
    });
  
    collapse.addEventListener('click', (e) => {
      e.preventDefault();
      document.querySelectorAll('#content details').forEach((elt) => {
        elt.removeAttribute('open');
      });
    });
  </script>
<% end %>