<h3 class="landmark"><%= ts("Filters") %></h3>
<%= form_tag admin_posts_path, :class => 'horizontal', :method => :get do %>
  <span class="form-row">
    <%= label_tag :tag, ts("Tag:") %>
    <%= select_tag :tag, ('<option></option>' + options_from_collection_for_select(@tags, :id, :name, params[:tag])).html_safe %>
  </span>
  <span class="form-row">
    <%= label_tag :language_id, ts("Language:") %>
    <%= select_tag :language_id, options_for_select(language_options_for_select(@news_languages, "short"), params[:language_id] || Language.default.short) %>
  </span>
  <span class="submit">
    <%= submit_tag ts('Go') %>
  </span>
<% end %>
