<!--Descriptive page name, messages and instructions-->
<h2><%= t(".page_title", login: current_admin.login) %></h2>
<!--/descriptions-->

<!--subnav-->
<!--/subnav-->

<!--main content-->
<div id="content" class="admin">
  <p><%= t(".confidentiality_reminder") %></p>

  <div class="important"><%= t(".log_out_reminder") %></div>

  <hr />

  <h3><%= t(".account.heading") %></h3>
    <dl class="account meta group">
      <div class="role wrapper">
        <dt><%= t(".account.roles.label") %></dt>
        <dd>
          <% if current_admin.roles.any? %>
            <ul class="commas">
              <% current_admin.roles.each do |role| %>
                <li><%= t("activerecord.attributes.admin/role.#{role}") %></li>
              <% end %>
            </ul>
          <% else %>
            <p><%= t(".account.roles.none") %></p>
          <% end %>
        </dd>
      </div>

      <div class="verification wrapper">
        <dt><%= t(".account.totp.label") %></dt>
        <% if current_admin.totp_enabled? %>
          <dd>
            <p><%= t(".account.totp.enabled") %></p>
            <p>
              <%= link_to t(".account.totp.disable_totp"), confirm_disable_admin_totp_path(current_admin) %>
            </p>
            <p>
              <%= link_to t(".account.totp.regenerate_backup_codes"), show_backup_codes_admin_totp_path(current_admin) %>
            </p>
          </dd>
        <% else %>
          <dd>
            <p><%= t(".account.totp.disabled") %></p>
            <p><%= link_to t(".account.totp.enable_totp"), new_admin_totp_path(current_admin) %></p>
          </dd>
        <% end %>
      </div>
    </dl>
  </div>
</div>
<!--/content-->
