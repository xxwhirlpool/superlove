#!/bin/bash
me="vagrant"
CONF=/home/katmac3/superlove/otwarchive/config/unicorn.rb
export UNICORN_PORT=9292
export UNICORNS=8
unicorn_master_pid=`ps ax | grep $me.sock | grep master | awk '{print $1}'`
if [ "$unicorn_master_pid" != "" ]; then
  echo "removing old unicorn master"
  /home/katmac3/superlove/otwarchive/bin/kill_my_unicorns
  sleep 5
fi
echo "starting new unicorn master"
if [ -f "config.ru" ]; then
  #LOC=`pwd -P`
  #echo setting $HOME/app/current to $LOC
  #rm $HOME/app/current
  #ln -s "$LOC" "$HOME/app/current"

  #$HOME/bin/create_links_on_install
  SUPERLOVE_HASH=#$(git rev-parse --short=8 HEAD)
  echo
  bundle exec unicorn -l /tmp/${me}.sock -c $CONF > /home/katmac3/superlove/otwarchive/log/"$RAILS_ENV"_new.log 2>&1 &
  #files=(/usr/local/etc/art/unicorn_*)
  #WHICH="${files[RANDOM % ${#files[@]}]}"
  #cat $WHICH
  #Now start the pseud watcher
#  nohup /home/otw/otwarchive/bin/pseud_watcher.sh &
  #now start the collection watcher
#  nohup /home/otw/otwarchive/bin/collection_watcher.sh &
  echo "done"
else
  echo "Ooops! You don't appear to be in your rails application directory"
fi
